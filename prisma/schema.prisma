// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  SUPER_ADMIN
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum ResultType {
  HOME // 1 — gana el local
  DRAW // X — empate
  AWAY // 2 — gana el visitante
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nickGlobal   String   @unique
  avatar       String?
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())

  memberships          Member[]
  predictions          Prediction[]
  points               Points[]
  adminGroups          Group[]              @relation("GroupAdmin")
  passwordResetTokens  PasswordResetToken[]
  predictionHistories  PredictionHistory[]
  tournamentPredictions TournamentPrediction[]
  groupRankings        GroupRanking[]
  globalRanking        GlobalRanking?
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Group {
  id               String   @id @default(cuid())
  name             String
  image            String?
  inviteCode       String   @unique
  inviteExpiresAt  DateTime
  createdAt        DateTime @default(now())
  adminId          String

  admin       User         @relation("GroupAdmin", fields: [adminId], references: [id])
  members             Member[]
  predictions         Prediction[]
  points              Points[]
  predictionHistories PredictionHistory[]
  tournamentPredictions TournamentPrediction[]
  groupRankings       GroupRanking[]
}

model Member {
  userId   String
  groupId  String
  nick     String
  role     MemberRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@unique([groupId, nick])
}

model Match {
  id               String      @id @default(cuid())
  externalId       Int?        @unique
  homeTeam         String
  awayTeam         String
  homeTeamCrest    String?
  awayTeamCrest    String?
  date             DateTime
  phase            String
  groupStageNumber Int?
  jornada          Int         @default(1)
  status           MatchStatus @default(SCHEDULED)
  homeGoals        Int?
  awayGoals        Int?

  predictions         Prediction[]
  predictionHistories PredictionHistory[]

  @@index([status])
  @@index([date])
}

model Prediction {
  id                  String     @id @default(cuid())
  userId              String
  matchId             String
  groupId             String
  predictionHomeGoals Int
  predictionAwayGoals Int
  resultType          ResultType
  pointsEarned        Int?
  scoredAt            DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, groupId])
}

model Points {
  userId  String
  groupId String
  points  Int    @default(0)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model PredictionHistory {
  id                  String   @id @default(cuid())
  predictionId        String
  userId              String
  matchId             String
  groupId             String
  predictionHomeGoals Int
  predictionAwayGoals Int
  action              String   // "CREATE" | "UPDATE"
  createdAt           DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model TournamentPrediction {
  userId      String
  groupId     String
  champion    String?
  runnerUp    String?
  thirdPlace  String?
  worstTeam   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
}

model TournamentResult {
  id         String  @id @default("singleton")
  champion   String?
  runnerUp   String?
  thirdPlace String?
}

model GroupRanking {
  groupId          String
  userId           String
  position         Int
  points           Int
  matchPoints      Int
  bonusPoints      Int
  championPoints   Int
  runnerUpPoints   Int
  thirdPlacePoints Int
  worstTeamPoints  Int
  exactCount       Int
  championCorrect  Boolean
  updatedAt        DateTime @updatedAt

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([groupId, position])
}

model GlobalRanking {
  userId                String   @id
  position              Int
  points                Int
  matchPoints           Int
  bonusPoints           Int
  exactCount            Int
  correctChampionGroups Int
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([position])
}

